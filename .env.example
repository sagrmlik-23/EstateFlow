# ══════════════════════════════════════════════════════════════════════════════
# EstateFlow CRM — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in all values.
# ══════════════════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Database (Supabase) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:***@db.xxxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:***@db.xxxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...VCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...VCJ9...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Public Supabase (exposed to browser) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...VCJ9...

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis (Rate Limiting + Caching) ─────────────────────────────────────────
REDIS_URL=redis://default:***@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Upstash Redis (edge-compatible) ─────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
UPSTASH_REDIS_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-token

# ─── Vercel Edge Config (Tenant Routing Cache) ───────────────────────────────
EDGE_CONFIG=ecfg_xxxxxxxxxxxx
EDGE_CONFIG_ITEM_KEY=tenant-routing

# ─── Encryption (AES-256-GCM for PII fields) ─────────────────────────────────
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2
APP_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# ─── AI Voice Agents ─────────────────────────────────────────────────────────
# Bland AI — Voice agent provider
BLAND_AI_KEY=your-bland-ai-api-key
# Retell AI — Alternative voice agent provider
RETELL_AI_KEY=your-retell-ai-api-key
# Vapi — Alternative voice agent provider
VAPI_API_KEY=your-vapi-api-key
# OpenRouter — LLM gateway for transcript analysis & chatbot
OPENROUTER_API_KEY=your-openrouter-api-key
# Groq — Ultra-fast LLM inference for real-time responses
GROQ_API_KEY=your-groq-api-key

# ─── Communication — SMS/WhatsApp ────────────────────────────────────────────
# Exotel — Voice calls & SMS (India)
EXOTEL_SID=your-exotel-sid
EXOTEL_TOKEN=your-exotel-token
EXOTEL_SUBDOMAIN=your-subdomain
# Twilio — Voice calls & SMS (Global)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# WATI — WhatsApp Business API
WATI_API_KEY=your-wati-api-key
WATI_API_URL=https://live.wati.io
WATI_PHONE_NUMBER_ID=your-wati-phone-number-id
# MSG91 — SMS & WhatsApp (India)
MSG91_API_KEY=your-msg91-api-key
MSG91_SENDER_ID=ESTATE
MSG91_ROUTE=4

# ─── Communication — Email ───────────────────────────────────────────────────
# Resend — Transactional email delivery
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@estateflow.app
RESEND_FROM_NAME=EstateFlow CRM
# SMTP Fallback (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_FROM_EMAIL=noreply@estateflow.app

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ─── Monitoring & Observability ──────────────────────────────────────────────
# Sentry — Error tracking & performance monitoring
SENTRY_DSN=https://xxxxxxxxxxxxxx@sentry.io/xxxxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=estateflow-crm
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxx@sentry.io/xxxxxx
# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ─── PWA / Push Notifications ────────────────────────────────────────────────
# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNk...your-vapid-public-key...AAAA
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@estateflow.app

# ─── Cron / Background Jobs ──────────────────────────────────────────────────
# Cron secret for securing cron endpoints
CRON_SECRET=your-cron-secret-at-least-16-chars
# AI Call Queue cron
AI_CALL_QUEUE_BATCH_SIZE=10
AI_CALL_QUEUE_INTERVAL_MINUTES=5

# ─── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_CHATBOT=true
NEXT_PUBLIC_ENABLE_AI_AGENTS=true
NEXT_PUBLIC_ENABLE_PWA_INSTALL_PROMPT=true
ENABLE_BILLING=true

# ─── Rate Limiting (per-tier configuration) ──────────────────────────────────
RATE_LIMIT_DEFAULT_RPS=10
RATE_LIMIT_AI_RPS=5
RATE_LIMIT_WEBHOOK_RPS=20

# ─── Tenant Routing ──────────────────────────────────────────────────────────
PLATFORM_DOMAIN=estateflow.app
DEFAULT_TENANT_SLUG=demo

# ─── File Upload ─────────────────────────────────────────────────────────────
# Max file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760
# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ─── Session / Cookie ────────────────────────────────────────────────────────
SESSION_SECRET=your-session-secret-at-least-32-chars-long
COOKIE_DOMAIN=.estateflow.app
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
